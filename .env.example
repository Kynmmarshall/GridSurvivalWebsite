# GA4 Data API configuration
# Numeric GA4 Property ID (Admin -> Property details)
GA4_PROPERTY_ID=512236469

# Option A: paste full JSON on one line
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key":"-----BEGIN PRIVATE KEY-----\\nYOUR_KEY\\n-----END PRIVATE KEY-----\\n","client_email":"ga4-reader@your-project.iam.gserviceaccount.com"}

# Option A2 (recommended): reference a JSON key file path
# GA4_SERVICE_ACCOUNT_FILE=/var/www/GridSurvivalWebsite/ga4-service-account.json

# Option B: provide pieces below
# IMPORTANT: do not paste a raw multiline private key directly in .env.
# Use \n markers in a single line, or prefer GA4_SERVICE_ACCOUNT_FILE / GA4_PRIVATE_KEY_BASE64.
GA4_CLIENT_EMAIL=ga4-reader@your-project.iam.gserviceaccount.com
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# Option C (recommended for VPS): base64-encode the full private key PEM
# GA4_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0tCk...

# Optional
PORT=3002

# Start date used for total download count (all-time metric)
GA4_DOWNLOADS_START_DATE=2024-01-01

# Persist last successful analytics payload across deploys/restarts
# For VPS, use a path outside the git repo (recommended).
ANALYTICS_CACHE_FILE=/var/www/grid-survival-data/analytics-cache.json
